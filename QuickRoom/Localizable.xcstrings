    "We need a few permissions from you to make our app work and help you manage your bookings." : {
      "comment" : "A description of the permissions that the app needs.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kami memerlukan beberapa izin dari Anda agar aplikasi kami dapat berfungsi dan membantu Anda mengelola reservasi."
          }
        },
        "uz" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ilovamiz ishlashi va bandlovlarni boshqarishga yordam berishi uchun sizdan bir nechta ruxsatnomalar talab qilinadi."
          }
        },
        "uz-UZ" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ilovamiz ishlashi va bandlovlarni boshqarishga yordam berishi uchun sizdan bir nechta ruxsatnomalar talab qilinadi."
          }
        }
      }
    },
    "We need time sensitive notification support to let you know of important notifications such as auto release and your reservation ending notification when you are focused." : {
      "comment" : "Permission row view description for time sensitive notification.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kami memerlukan dukungan notifikasi sensitif waktu untuk memberi tahu Anda tentang pemberitahuan penting seperti pelepasan otomatis dan notifikasi berakhirnya reservasi saat Anda sedang fokus."
          }
        },
        "uz" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Diqqatni jamlagan vaqtingizda avtomatik boʻshatish va bandlov tugashi kabi muhim bildirishnomalardan xabardor qilishimiz uchun vaqtga sezgir bildirishnoma ruxsati kerak."
          }
        },
        "uz-UZ" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Diqqatni jamlagan vaqtingizda avtomatik boʻshatish va bandlov tugashi kabi muhim bildirishnomalardan xabardor qilishimiz uchun vaqtga sezgir bildirishnoma ruxsati kerak."
          }
        }
      }
    },
    "We need your always location access to know when you enter or exit our managed meeting rooms, we do not track your location." : {
      "comment" : "Description of a permission row view for location access.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kami memerlukan akses lokasi Anda setiap saat untuk mengetahui kapan Anda memasuki atau keluar dari ruang rapat yang kami kelola, kami tidak melacak lokasi Anda."
          }
        },
        "uz" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Biz boshqaradigan majlislar xonalariga qachon kirganingiz yoki chiqqaningizni bilishimiz uchun joylashuvga doimiy ruxsat kerak, joylashuvingizni kuzatmaymiz."
          }
        },
        "uz-UZ" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Biz boshqaradigan majlislar xonalariga qachon kirganingiz yoki chiqqaningizni bilishimiz uchun joylashuvga doimiy ruxsat kerak, joylashuvingizni kuzatmaymiz."
          }
        }
      }
    },
    "We need your notification permission to let you know of upoming bookings, rservation ending, auto release notifications, and more." : {
      "comment" : "Text displayed in a row of a permission sheet.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
