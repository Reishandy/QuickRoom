            "value" : "Kami memerlukan izin notifikasi Anda untuk memberi tahu Anda tentang reservasi mendatang, reservasi berakhir, notifikasi pelepasan otomatis, dan banyak lagi."
          }
        },
        "uz" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kutilayotgan bandlovlar, bandlov tugashi, avtomatik boʻshatish va boshqalar haqida xabar berib turishimiz uchun bildirishnomalarga ruxsat berishingiz kerak."
          }
        },
        "uz-UZ" : {
